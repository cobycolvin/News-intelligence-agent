APP_NAME=Multimodal News Intelligence Agent
APP_ENV=development
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=

MOCK_MODE=true
SAMPLE_DATA_PATH=sample_data/articles.json

LIVE_INGESTION_ENABLED=false
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_API_LANGUAGE=en
NEWS_API_PAGE_SIZE=30
INGESTION_TIMEOUT_SECONDS=12
INGESTION_EXTRACT_FULL_TEXT=false
INGESTION_ARTICLE_TIMEOUT_SECONDS=8
INGESTION_FULL_TEXT_MAX_ARTICLES=6
INGESTION_FULL_TEXT_MAX_WORKERS=4
INGESTION_USE_NEWSPAPER=false
INGESTION_MAX_RUNTIME_SECONDS=180
INGESTION_PLACEHOLDER_IMAGE_URL=https://via.placeholder.com/1280x720?text=No+Image

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=sentence-transformers/all-mpnet-base-v2
VECTOR_DB_PATH=backend/.chroma
VECTOR_STORE_BACKEND=memory
VECTOR_STORE_DATABASE_URL=
VECTOR_STORE_TABLE_NAME=article_embeddings
VECTOR_STORE_DIMENSION=32
MAX_ARTICLES_DEFAULT=5

VISION_PROVIDER=local
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

SYNTHESIS_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
